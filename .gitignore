# Python virtual environments
.venv/
venv/

# Python bytecode caches
__pycache__/
*.pyc
*.pyo

# uv lock cache
.uv/

# Editor / OS noise
.DS_Store
.idea/
.vscode/

# Per-seed ensemble run CSVs (large; produced by
# scripts/regenerate_outputs.py --n-seeds N>1). Committed ensemble
# artefacts (summary CSV + band PNG) live in outputs/ alongside the
# regular scenario outputs.
ensemble_runs/

# Surrogate-training artefacts. The .pkl bundles are large (~10 MB
# each) and regenerable from the per-mineral parquets. The canonical
# copy lives on NERSC at
#   /global/cfs/cdirs/amsc001/www/surrogate_data/surrogate_models/
# (web-portal: https://portal.nersc.gov/project/amsc001/surrogate_data/).
# We DO commit the small `*_scalar.metrics.json` side-cars so anyone
# can see at a glance what the trained ensemble's held-out metrics
# look like without pulling 31 MB of pickles.
surrogate_models/*.pkl
# Cached quantile training summary; regenerable from the per-bundle
# .metrics.json side-cars.
surrogate_models/quantile_summary.json

# Local cache directory for parquets pulled from CFS during ad-hoc
# training runs. The canonical parquets live under CFS datasets/.
datasets_perlmutter/

# Trajectory-surrogate model bundles. Same convention as
# surrogate_models/: only the *_trajectory.metrics.json side-cars are
# tracked; the .pkl bundles (with the torch state_dict embedded) are
# regenerable from the per-mineral parquets / runs and live on
# CFS / Lustre.
trajectory_models/*.pkl
trajectory_models_v2/*.pkl
trajectory_models_smoke/

# Local cache of GBT/CSV/scenarios pulled from CFS / scratch for
# eval scripts. Regenerable; canonical copies live on NERSC.
local_eval_data/

# Per-record trajectory tensor caches (.pt) materialised by the
# TrajectoryDataset.  Regenerable from the per-mineral runs on CFS.
trajectory_cache/

# US-policy sweep artefacts -- per-job summary.csv / figures / H5
# trajectories are large and regenerable from
#   scripts/build_policy_scenarios.py + scripts/sweep_mpi.slurm.
# Canonical copies (figures + summary.csv) live on NERSC under
#   /global/cfs/cdirs/amsc001/www/uspolicy/
# Web portal: https://portal.nersc.gov/project/amsc001/uspolicy/
runs/

# Local diagnostics / inspectors used during the substitution-paradox
# investigation. One-off scripts, not part of the canonical pipeline.
diagnose_*.py
diagnose_*_results.csv
inspect_*.py
verify_compact.py
compare_bufix.py

# Built scenario JSONs (regenerable from scripts/build_policy_scenarios.py
# + the param-grid JSON which IS committed).
scenarios/sweep_*.json
!scenarios/sweep_*_param_grid.json

# Older Dockerfile drafts kept locally for reference; the canonical
# images are tagged on Docker Hub and rebuildable from
# Containerfile.podman-mpi (podman-hpc / Perlmutter) or
# Dockerfile.us-policy (laptop / Shifter fallback).
Dockerfile.mpi
Dockerfile.mpi-v2
Dockerfile.mpi-v3
